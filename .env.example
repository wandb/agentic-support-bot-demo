# Weights & Biases API Key for Weave observability (Required)
# Get your key from: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# Weights & Biases Project Name
# IMPORTANT: Use format "your-entity/project-name" (e.g., "wandb-designers/agentic-support-bot-yourname")
# Find your entity at: https://wandb.ai/settings
# Add a unique suffix to avoid conflicts with other users
# This controls Weave initialization in Tyler Chat CLI and scripts
WANDB_PROJECT=your-entity/agentic-support-bot-demo-yourname

# OpenAI API Key (Required for Step 6 guardrails)
# Used for:
# - Input guardrail (OpenAI Moderation API) - blocks toxic requests
# - LLM access if using OpenAI models
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# API key for authenticating requests to your support bot server
# Set this to any value (e.g., "my-secret-key-123")
# This will be used when creating Modal secrets and in W&B Team Secrets
AGENTIC_SUPPORT_BOT_API_KEY=your_bot_api_key_here
