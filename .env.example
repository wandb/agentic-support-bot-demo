# Weights & Biases API Key for Weave observability (Required)
# Get your key from: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# Weights & Biases Project Name
# This controls Weave initialization in Tyler Chat CLI and scripts
WANDB_PROJECT=agentic-support-bot-demo

# OpenAI API Key for LLM access (Optional - configure based on your LLM provider)
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Playground Server API Key (Required for playground_server.py)
# Used for authentication when connecting to the playground server
# This key should match the one you configure in W&B Team Secrets
PLAYGROUND_API_KEY=your_secret_api_key_here

# Optional: Playground Server Configuration
# PLAYGROUND_SERVER_HOST=0.0.0.0
# PLAYGROUND_SERVER_PORT=8000
# PLAYGROUND_LOG_LEVEL=INFO

# Ngrok Auth Token (Required for playground_server.py)
# Get your token from: https://dashboard.ngrok.com/get-started/your-authtoken
# Used to create a public tunnel to your local playground server
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
